# === Deployment Mode ===
# combined  — Samba4 DC + Web UI (for development/testing)
# standalone — Web UI only (connects to an existing DC)
DEPLOY_MODE=combined

# === Web UI ===
# Combined mode: use Docker service names (samba-ad)
# Standalone mode: use your DC hostname/IP
LDAP_URL=ldap://samba-ad:389
LDAPS_URL=ldaps://samba-ad:636
LDAP_BASE_DN=DC=lab,DC=dev

# TLS certificate validation for LDAPS
# Set to false for self-signed DC certificates
LDAP_TLS_REJECT_UNAUTHORIZED=false

# Path to custom CA certificate bundle (PEM format) for LDAPS
# LDAP_CA_CERT_PATH=/etc/ssl/certs/my-ca.pem

# JWT authentication (auto-generated by setup.sh)
JWT_SECRET=change-me-in-production
JWT_EXPIRY=8h

# Encryption key for credentials in JWT (32 bytes hex, auto-generated by setup.sh)
CREDENTIAL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SSL mode for the Web UI: self-signed or none
SSL_MODE=none
SSL_DOMAIN=

# Ports
APP_PORT=3000
APP_INTERNAL_PORT=3000

# Rate Limiting (per user, fixed window)
# RATE_LIMIT_WRITE_WINDOW_MS=60000
# RATE_LIMIT_WRITE_MAX=30
# RATE_LIMIT_READ_WINDOW_MS=60000
# RATE_LIMIT_READ_MAX=60

# === Samba4 DC (combined mode only) ===
SAMBA_DOMAIN=LAB
SAMBA_REALM=LAB.DEV
SAMBA_REALM_LOWER=lab.dev
SAMBA_ADMIN_PASS=Admin1234!
BIND_IP=127.0.0.1
DNS_FORWARDER=8.8.8.8

# === Development ===
# PORT=3001
# NODE_ENV=development
