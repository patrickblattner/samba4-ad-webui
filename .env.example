# LDAP Connection
LDAP_URL=ldap://localhost:389
LDAPS_URL=ldaps://localhost:636
LDAP_BASE_DN=DC=lab,DC=dev

# TLS certificate validation for LDAPS (default: true in production, false in development)
# Set to false only for self-signed certificates in dev/test environments
# LDAP_TLS_REJECT_UNAUTHORIZED=true

# Path to custom CA certificate bundle (PEM format) for LDAPS
# LDAP_CA_CERT_PATH=/etc/ssl/certs/my-ca.pem

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=15m

# Encryption key for credentials in JWT (32 bytes hex)
CREDENTIAL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Rate Limiting (per user, fixed window)
# RATE_LIMIT_WRITE_WINDOW_MS=60000
# RATE_LIMIT_WRITE_MAX=30
# RATE_LIMIT_READ_WINDOW_MS=60000
# RATE_LIMIT_READ_MAX=60

# Server
PORT=3001
NODE_ENV=development
